{
  "name": "FanHub Workshop",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "customizations": {
    "vscode": {
      "extensions": [
        // Core AI tools
        "github.copilot",
        "github.copilot-chat",
        // Node.js / TypeScript (all frontends + Node backend)
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        // Go
        "golang.go",
        // Java
        "vscjava.vscode-java-pack",
        // .NET / C#
        "ms-dotnettools.csdevkit",
        // SQLite
        "qwtel.sqlite-viewer",
        // Docker
        "ms-azuretools.vscode-docker",
        // Markdown
        "bierner.markdown-mermaid",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csdevkit"
        },
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        },
        "js/ts.updateImportsOnFileMove.enabled": "always",
        "github.copilot.enable": {
          "*": true,
          "markdown": true,
          "javascript": true,
          "typescript": true,
          "javascriptreact": true,
          "typescriptreact": true,
          "go": true,
          "java": true,
          "csharp": true
        }
      }
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },

  "forwardPorts": [3000, 5265],
  "portsAttributes": {
    "3000": {
      "label": "Frontend (all languages)",
      "onAutoForward": "notify"
    },
    "5265": {
      "label": "Backend API (all languages)",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "echo '✓ Dev container ready! Choose your language and follow its SETUP.md: node/ | go/ | java/ | dotnet/'",

  "remoteUser": "codespace"
}
